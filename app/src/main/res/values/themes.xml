<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema Material para que colorPrimary y colorAccent se apliquen a botones y FAB -->
    <style name="Theme.TripPlanner" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@color/background_light</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/teal_dark</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="colorPrimary">@color/primary_teal</item>
        <item name="colorPrimaryVariant">@color/teal_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_orange</item>
        <item name="colorSecondaryVariant">@color/orange_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorError">@color/orange_dark</item>
    </style>
</resources>
